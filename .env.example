# ===========================================================================
# fpbot — variáveis de ambiente
# Copie para .env e preencha com os valores reais. NUNCA commite o .env.
# ===========================================================================

# --- Slack ---
# Bot OAuth Token (Settings → OAuth & Permissions → Bot User OAuth Token)
SLACK_BOT_TOKEN=xoxb-

# App-Level Token para Socket Mode (Settings → Basic Information → App-Level Tokens)
# Escopo necessário: connections:write
SLACK_APP_TOKEN=xapp-

# Signing Secret (Settings → Basic Information → App Credentials)
SLACK_SIGNING_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-

# --- Supabase ---
# URL do projeto (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co

# Service Role Key — bypass RLS. NÃO expor em frontend.
SUPABASE_SERVICE_KEY=

# --- WikiJS ---
# URL base da sua instância WikiJS (sem barra no final)
WIKIJS_URL=https://wiki.suaempresa.com

# Token de API (WikiJS Admin → Administration → API Access → Create Token)
# Permissões necessárias: read:pages
WIKIJS_API_TOKEN=
